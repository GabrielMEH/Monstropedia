<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="0dp">

    <!-- Ícone (lado esquerdo) -->
    <ImageView
        android:id="@+id/imgIconeMonstro"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:contentDescription="Ícone do Monstro"
        android:src="@drawable/hunt_quest_icon" />

    <!-- Nome do Monstro (centro) -->
    <TextView
        android:id="@+id/txtNomeMonstroLinha"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:layout_weight="1"
        android:height="40dp"
        android:background="@drawable/name_background"
        android:fontFamily="sans-serif"
        android:gravity="center_vertical"
        android:paddingLeft="5dp"
        android:paddingRight="0dp"
        android:text="Nome do Monstro"
        android:textColor="@android:color/white"
        android:textSize="20sp"
        android:textStyle="bold" />

    <!-- Nível de Desafio (CR) (lado direito) -->
    <TextView
        android:id="@+id/txtCRMonstroLinha"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:fontFamily="sans-serif"
        android:gravity="center"
        android:text="CR 10"
        android:textColor="@color/CR"
        android:textSize="22sp"
        android:textStyle="bold" />

</LinearLayout>
